{
  "arch": "mips64",
  "cpu": "mips3",
  "data-layout": "e-m:e-p:32:32-i8:8:32-i16:16:32-i64:64-i128:128-n32:64-S128",
  "executables": true,
  "features": "+single-float",
  "linker": "mips64r5900el-ps2-elf-ld",
  "linker-flavor": "ld",
  "llvm-target": "mips64el-unknown-none-elf",
  "max-atomic-width": 0,
  "os": "ps2",
  "panic-strategy": "abort",
  "position-independent-executables": false,
  "relro-level": "full",
  "target-c-int-width": 32,
  "target-endian": "little",
  "target-pointer-width": 32,
  "vendor": "sony",
  "abi": "n32",
  "llvm-abiname": "n32",
  "relocation-model": "static",
  "post-link-args": {
    "ld": ["-Tps2sdk/linkfile", "-melf32lr5900n32"]
  }
}
